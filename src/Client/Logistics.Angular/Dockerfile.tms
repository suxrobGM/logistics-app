# Stage 1: Build
FROM oven/bun:latest AS builder
WORKDIR /app

# Copy package files
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy source
COPY . .

# Build shared library and TMS Portal
RUN bun run build:shared
RUN bun run build:tms

# Stage 2: Runtime
FROM nginx:alpine

# Copy nginx config
COPY nginx.conf /etc/nginx/nginx.conf

# Copy built app
COPY --from=builder /app/dist/tms-portal/browser /usr/share/nginx/html

# Runtime environment variable substitution for secrets
COPY docker-entrypoint-tms.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENV MAPBOX_TOKEN=""
ENV STRIPE_PUBLISHABLE_KEY=""

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
