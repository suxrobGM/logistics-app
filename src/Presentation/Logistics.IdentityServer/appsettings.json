{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.AspNetCore.DataProtection": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/identityapp-.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Month"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithExceptionDetails"
    ]
  },
  "ConnectionStrings": {
    "MasterDatabase": "Host=localhost; Port=5432; Database=master_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true",
    "DefaultTenantDatabase": "Host=localhost; Port=5432; Database=default_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true"
  },
  "TenantsDatabaseConfig": {
    "DatabaseNameTemplate": "{tenant}_logisticsx",
    "DatabaseHost": "localhost",
    "DatabasePort": 5432,
    "DatabaseUserId": "postgres",
    "DatabasePassword": "Test12345#"
  },
  "Authentication": {
    "Google": {
      "ClientId": "<Google OAuth Client ID>",
      "ClientSecret": "<Google OAuth Client Secret>"
    }
  },
  "GoogleRecaptcha": {
    "SiteKey": "<Google captcha site key>",
    "SecretKey": "<Google captcha secret key>"
  },
  "Impersonation": {
    "TmsPortalUrl": "http://localhost:7003"
  },
  "Resend": {
    "ApiKey": "<Resend API key>",
    "SenderEmail": "noreply@logisticsx.app",
    "SenderName": "LogisticsX"
  },
  "IdentityServer": {
    "Clients": [
      {
        "Enabled": true,
        "ClientId": "logisticsx.adminportal",
        "ClientName": "LogisticsX Admin Portal",
        "RequireClientSecret": false,
        "AllowedGrantTypes": [
          "authorization_code"
        ],
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "RedirectUris": [
          "http://localhost:7002",
          "https://admin.logisticsx.app"
        ],
        "PostLogoutRedirectUris": [
          "http://localhost:7002",
          "https://admin.logisticsx.app"
        ],
        "AllowedCorsOrigins": [
          "http://localhost:7002",
          "https://admin.logisticsx.app"
        ],
        "AllowOfflineAccess": true,
        "AllowedScopes": [
          "openid",
          "profile",
          "roles",
          "tenant",
          "logisticsx.api.admin"
        ]
      },
      {
        "Enabled": true,
        "ClientId": "logisticsx.tmsportal",
        "ClientName": "LogisticsX TMS Portal",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": [
          "authorization_code"
        ],
        "RedirectUris": [
          "http://localhost:7003",
          "https://tms.logisticsx.app"
        ],
        "PostLogoutRedirectUris": [
          "http://localhost:7003",
          "https://tms.logisticsx.app"
        ],
        "AllowedCorsOrigins": [
          "http://localhost:7003",
          "https://tms.logisticsx.app"
        ],
        "AllowOfflineAccess": true,
        "AllowedScopes": [
          "openid",
          "profile",
          "roles",
          "tenant",
          "logisticsx.api.tenant"
        ]
      },
      {
        "Enabled": true,
        "ClientId": "logisticsx.customerportal",
        "ClientName": "LogisticsX Customer Portal",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": [
          "authorization_code"
        ],
        "RedirectUris": [
          "http://localhost:7004",
          "https://customer.logisticsx.app"
        ],
        "PostLogoutRedirectUris": [
          "http://localhost:7004",
          "https://customer.logisticsx.app"
        ],
        "AllowedCorsOrigins": [
          "http://localhost:7004",
          "https://customer.logisticsx.app"
        ],
        "AllowOfflineAccess": true,
        "AllowedScopes": [
          "openid",
          "profile",
          "roles",
          "tenant",
          "logisticsx.api.tenant"
        ]
      },
      {
        "Enabled": true,
        "ClientId": "logisticsx.driverapp",
        "ClientName": "LogisticsX Driver App",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": [
          "password",
          "refresh_token"
        ],
        "AllowOfflineAccess": true,
        "AllowedScopes": [
          "openid",
          "profile",
          "roles",
          "tenant",
          "logisticsx.api.tenant",
          "offline_access"
        ]
      }
    ]
  }
}
