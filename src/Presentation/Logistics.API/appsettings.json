{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/webapi-.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Month"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithExceptionDetails"
    ]
  },
  "ConnectionStrings": {
    "MasterDatabase": "Host=localhost; Port=5432; Database=master_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true",
    "DefaultTenantDatabase": "Host=localhost; Port=5432; Database=default_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true"
  },
  "TenantsDatabaseConfig": {
    "DatabaseNameTemplate": "{tenant}_logisticsx",
    "DatabaseHost": "localhost",
    "DatabasePort": 5432,
    "DatabaseUserId": "postgres",
    "DatabasePassword": "Test12345#"
  },
  "IdentityServer": {
    "Authority": "http://localhost:7001",
    "Audience": "logisticsx.api",
    "ValidIssuers": [
      "http://localhost:7001",
      "https://localhost:7001",
      "http://10.0.2.2:7001",
      "https://10.0.2.2:7001",
      "https://id.logisticsx.app",
      "http://identity-server:7001"
    ]
  },
  "CustomerPortal": {
    "BaseUrl": "http://localhost:7004"
  },
  "Impersonation": {
    "MasterPassword": "CHANGE_THIS_SECURE_MASTER_PASSWORD",
    "TokenExpirationMinutes": 5
  },
  "Resend": {
    "ApiKey": "<Resend API key>",
    "SenderEmail": "noreply@logisticsx.app",
    "SenderName": "LogisticsX"
  },
  "Stripe": {
    "SecretKey": "<Stripe secret key>",
    "WebhookSecret": "<Stripe webhook secret>"
  },
  "BlobStorage": {
    "Type": "File"
  },
  "FileBlobStorage": {
    "BaseUrl": "http://localhost:7000",
    "RootPath": "wwwroot/uploads",
    "RequestPath": "/uploads",
    "CacheSeconds": 3600
  },
  "Mapbox": {
    "AccessToken": "<Mapbox access token>"
  },
  "Llm": {
    "DefaultProvider": "Anthropic",
    "MaxTokens": 8192,
    "Providers": {
      "Anthropic": {
        "ApiKey": "<Anthropic API key>",
        "Model": "claude-haiku-4-5"
      },
      "OpenAi": {
        "ApiKey": "<OpenAI API key>",
        "Model": "gpt-5.4-mini"
      },
      "DeepSeek": {
        "ApiKey": "<DeepSeek API key>",
        "Model": "deepseek-chat",
        "BaseUrl": "https://api.deepseek.com/v1"
      }
    }
  },
  "TelegramBot": {
    "BotToken": "",
    "WebhookUrl": null,
    "SecretToken": null
  },
  "Eld": {
    "Samsara": {
      "BaseUrl": "https://api.samsara.com"
    },
    "Motive": {
      "BaseUrl": "https://api.keeptruckin.com/v1"
    },
    "TtEld": {
      "BaseUrl": "https://read.tteld.com"
    }
  }
}
