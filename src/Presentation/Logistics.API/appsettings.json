{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": ["Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/webapi-.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Month"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithThreadId", "WithExceptionDetails"]
  },
  "ConnectionStrings": {
    "MasterDatabase": "Host=localhost; Port=5432; Database=master_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true",
    "UsTenantDatabase": "Host=localhost; Port=5432; Database=us_logisticsx; Username=postgres; Password=Test12345#; Include Error Detail=true",
    "AzureBlobStorage": "<Azure Blob Storage connection string>"
  },
  "TenantDatabaseDefaults": {
    "NameTemplate": "{tenant}_logisticsx",
    "Host": "localhost",
    "Port": 5432,
    "UserId": "postgres",
    "Password": "Test12345#"
  },
  "IdentityServer": {
    "Authority": "http://localhost:7001",
    "Audience": "logisticsx.api",
    "ValidIssuers": [
      "http://localhost:7001",
      "https://localhost:7001",
      "http://10.0.2.2:7001",
      "https://10.0.2.2:7001",
      "https://id.logisticsx.app",
      "http://identity-server:7001"
    ]
  },
  "CustomerPortal": {
    "BaseUrl": "http://localhost:7004"
  },
  "Impersonation": {
    "MasterPassword": "CHANGE_THIS_SECURE_MASTER_PASSWORD",
    "TokenExpirationMinutes": 5
  },
  "Resend": {
    "ApiKey": "<Resend API key>",
    "SenderEmail": "noreply@logisticsx.app",
    "SenderName": "LogisticsX"
  },
  "Stripe": {
    "SecretKey": "<Stripe secret key>",
    "WebhookSecret": "<Stripe webhook secret>"
  },
  "BlobStorage": {
    "Type": "File"
  },
  "FileBlobStorage": {
    "BaseUrl": "http://localhost:7000",
    "RootPath": "wwwroot/uploads",
    "RequestPath": "/uploads",
    "CacheSeconds": 3600
  },
  "AzureBlobStorage": {
    "DefaultContainer": "documents"
  },
  "R2BlobStorage": {
    "AccountId": "<Cloudflare account id>",
    "AccessKeyId": "<R2 access key id>",
    "SecretAccessKey": "<R2 secret access key>",
    "BucketName": "logisticsx",
    "PublicBaseUrl": "https://cdn-logisticsx.suxrobgm.net"
  },
  "Mapbox": {
    "AccessToken": "<Mapbox access token>"
  },
  "Llm": {
    "DefaultProvider": "DeepSeek",
    "MaxTokens": 8192,
    "Providers": {
      "Anthropic": {
        "ApiKey": "<Anthropic API key>",
        "Model": "claude-haiku-4-5"
      },
      "OpenAi": {
        "ApiKey": "<OpenAI API key>",
        "Model": "gpt-5.4-mini"
      },
      "DeepSeek": {
        "ApiKey": "<DeepSeek API key>",
        "Model": "deepseek-v4-flash",
        "BaseUrl": "https://api.deepseek.com/v1"
      }
    }
  },
  "TelegramBot": {
    "BotToken": "<Telegram bot token>",
    "WebhookUrl": "https://api.logisticsx.app/webhooks/telegram",
    "SecretToken": null,
    "IdentityServerUrl": "https://id.logisticsx.app"
  },
  "Eld": {
    "Samsara": {
      "BaseUrl": "https://api.samsara.com"
    },
    "Motive": {
      "BaseUrl": "https://api.keeptruckin.com/v1"
    },
    "TtEld": {
      "BaseUrl": "https://read.tteld.com"
    }
  }
}
