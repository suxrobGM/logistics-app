#---------- Required: Image container names and ports ----------
API_IMAGE="ghcr.io/suxrobgm/logistics-app/api:latest"
IDENTITY_SERVER_IMAGE="ghcr.io/suxrobgm/logistics-app/identity:latest"

API_PORT=7000
IDENTITY_SERVER_PORT=7001

#---------- Required: Database (external PostgreSQL) ----------
ConnectionStrings__MasterDatabase="Host=localhost;Port=5432;Database=master_logisticsx;Username=postgres;Password=your-secure-password"
ConnectionStrings__DefaultTenantDatabase="Host=localhost;Port=5432;Database=default_logisticsx;Username=postgres;Password=your-secure-password"

# Tenant database creation settings (used when creating new tenants)
TenantsDatabaseConfig__DatabaseNameTemplate="{tenant}_logisticsx"
TenantsDatabaseConfig__DatabaseHost="localhost"
TenantsDatabaseConfig__DatabasePort=5432
TenantsDatabaseConfig__DatabaseUserId="postgres"
TenantsDatabaseConfig__DatabasePassword="your-secure-password"

#---------- Required: Identity Server (Authentication) ----------
# Use internal Docker network URL for API-to-IdentityServer communication
IdentityServer__Authority="http://identity-server:7001"
IdentityServer__ExternalAuthority="https://id.yourdomain.com"
IdentityServer__RequireHttpsMetadata="false"

#---------- Required: Stripe Integration ----------
Stripe__SecretKey="sk_live_xxx"
Stripe__WebhookSecret="whsec_xxx" # Either from Stripe dashboard or Stripe CLI

#---------- API: Common Settings ----------
CustomerPortal__BaseUrl="http://localhost:7004"
FileBlobStorage__BaseUrl="http://localhost:7000"

#---------- Required: Google OAuth (Sign in with Google) ----------
Authentication__Google__ClientId="your-google-client-id.apps.googleusercontent.com"
Authentication__Google__ClientSecret="GOCSPX-your-google-client-secret"

#---------- Required: Google reCAPTCHA (Identity Server) ----------
GoogleRecaptcha__SiteKey="your-site-key"
GoogleRecaptcha__SecretKey="your-secret-key"

#---------- Required: Impersonation (Admin Portal) ----------
Impersonation__MasterPassword="your-secure-master-password"
Impersonation__TmsPortalUrl="http://localhost:7003"

#---------- Required: Resend (Email) ----------
Resend__ApiKey="re_your_api_key_here"
Resend__SenderEmail="noreply@logisticsx.app"
Resend__SenderName="LogisticsX"

#---------- Optional: External Services ----------
# Mapbox (for maps)
Mapbox__AccessToken="pk.xxx"

# LLM API (for AI dispatch agent)
Llm__Providers__Anthropic__ApiKey="sk-ant-xxx"
Llm__Providers__OpenAi__ApiKey="sk-xxx"
Llm__Providers__DeepSeek__ApiKey="sk-xxx"

# Telegram Bot
TelegramBot__BotToken=""
TelegramBot__WebhookUrl="https://api.logisticsx.app/webhooks/telegram"
TelegramBot__SecretToken=""
TelegramBot__IdentityServerUrl="https://id.logisticsx.app"
