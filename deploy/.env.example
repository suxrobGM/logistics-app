#==============================================================================
# LogisticsX deployment environment — template for the DOCKER_ENV GitHub secret
# (copied to `.env` next to deploy/docker-compose.yml on the VPS).
#
# NOTE: GITHUB_REPOSITORY and IMAGE_TAG are appended automatically by the deploy
# workflow and select the GHCR images — do NOT put them in the secret. For a manual
# `docker compose` run, either export them or rely on the compose defaults
# (suxrobgm/logistics-app + latest).
#==============================================================================

#---------- Service ports (host-published on 127.0.0.1, fronted by nginx) ----------
API_PORT=7000
IDENTITY_SERVER_PORT=7001

#---------- Database (external PostgreSQL) ----------
ConnectionStrings__MasterDatabase="Host=localhost;Port=5432;Database=master_logisticsx;Username=postgres;Password=your-secure-password"
ConnectionStrings__UsTenantDatabase="Host=localhost;Port=5432;Database=us_logisticsx;Username=postgres;Password=your-secure-password"
# EuTenantDatabase is used by the DbMigrator only — the api container does not read it.
ConnectionStrings__EuTenantDatabase="Host=localhost;Port=5432;Database=eu_logisticsx;Username=postgres;Password=your-secure-password"

# Defaults applied when the API provisions new tenant databases
TenantDatabaseDefaults__NameTemplate="{tenant}_logisticsx"
TenantDatabaseDefaults__Host="localhost"
TenantDatabaseDefaults__Port=5432
TenantDatabaseDefaults__UserId="postgres"
TenantDatabaseDefaults__Password="your-secure-password"

#---------- Identity Server (Authentication) ----------
# Internal Docker network URL for API → IdentityServer is hardcoded in compose
# (http://identity-server:7001). ExternalAuthority is the public issuer URL.
IdentityServer__ExternalAuthority="https://id.yourdomain.com"

# API base URL the Identity Server calls back to (invitation validate/accept)
Api__BaseUrl="https://api.yourdomain.com"

#---------- Stripe ----------
Stripe__SecretKey="sk_live_xxx"
Stripe__WebhookSecret="whsec_xxx"

#---------- Common ----------
CustomerPortal__BaseUrl="https://customer.yourdomain.com"

#---------- Blob Storage ----------
# Provider selector: "File" (default), "Azure", "R2" / "Cloudflare"
BlobStorage__Type="File"
# File provider (used when BlobStorage__Type=File)
FileBlobStorage__BaseUrl="https://api.yourdomain.com"
# Azure (used when BlobStorage__Type=Azure)
ConnectionStrings__AzureBlobStorage="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AzureBlobStorage__DefaultContainer="documents"
# Cloudflare R2 (used when BlobStorage__Type=R2)
R2BlobStorage__AccountId="your-cloudflare-account-id"
R2BlobStorage__AccessKeyId="your-r2-access-key-id"
R2BlobStorage__SecretAccessKey="your-r2-secret-access-key"
R2BlobStorage__BucketName="logisticsx"
R2BlobStorage__PublicBaseUrl="https://cdn.yourdomain.com"

#---------- Google OAuth (Sign in with Google) ----------
Authentication__Google__ClientId="your-google-client-id.apps.googleusercontent.com"
Authentication__Google__ClientSecret="GOCSPX-your-google-client-secret"

#---------- Google reCAPTCHA (Identity Server) ----------
GoogleRecaptcha__SiteKey="your-site-key"
GoogleRecaptcha__SecretKey="your-secret-key"

#---------- Impersonation (Admin Portal) ----------
Impersonation__MasterPassword="your-secure-master-password"
Impersonation__TmsPortalUrl="https://tms.yourdomain.com"

#---------- Resend (Email) ----------
Resend__ApiKey="re_your_api_key_here"
Resend__SenderEmail="noreply@logisticsx.app"
Resend__SenderName="LogisticsX"

#---------- Optional: Mapbox (maps; also passed to the TMS portal) ----------
Mapbox__AccessToken="pk.xxx"

#---------- Optional: LLM providers (AI dispatch agent) ----------
Llm__Providers__Anthropic__ApiKey="sk-ant-xxx"
Llm__Providers__OpenAi__ApiKey="sk-xxx"
Llm__Providers__DeepSeek__ApiKey="sk-xxx"

#---------- Optional: Telegram Bot ----------
TelegramBot__BotToken=""
TelegramBot__WebhookUrl="https://api.logisticsx.app/webhooks/telegram"
TelegramBot__SecretToken=""
TelegramBot__IdentityServerUrl="https://id.logisticsx.app"
